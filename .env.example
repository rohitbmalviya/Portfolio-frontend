# =====================================================================
#  portfolio-frontend (Next.js — public site + /admin)  —  .env.example
#  Copy this file to ".env.local" and fill in your real values.
#  NEXT_PUBLIC_* vars are exposed to the browser; others are server-only.
# =====================================================================

# ── Public (browser-exposed) ────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Backend API base URL (public content reads)
NEXT_PUBLIC_API_URL=http://localhost:4000
# Contact button → opens email client to this address (mailto)
NEXT_PUBLIC_CONTACT_EMAIL=rohitbmalviya@gmail.com
# Default theme on first visit: dark | light  (still respects OS + user toggle)
NEXT_PUBLIC_DEFAULT_THEME=dark

# ── Server-only (the /admin area) ───────────────────────────────────
# Backend URL used by Next.js server-side code (same value as NEXT_PUBLIC_API_URL
# but not exposed to the browser — use in Route Handlers / Server Components if needed).
API_URL=http://localhost:4000
# Note: Auth is handled entirely by the NestJS backend (httpOnly cookie + JwtStrategy).
# The Next.js frontend does NOT sign its own session cookie; AUTH_COOKIE_SECRET is not used.
